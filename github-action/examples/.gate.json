{
  "enforce_mode": true,
  "block_on_findings": true,
  "notify_security": true,
  "check_bypasses": true,
  "rules_version": "v1.2.3",
  "skip_license_check": false,
  "allowed_patterns": [
    {
      "file": "docs/**/*.md",
      "rule": "aws-secret-key",
      "comment": "Documentation examples are intentionally redacted/mocked"
    },
    {
      "file": "test/fixtures/**",
      "rule": "api-key-exposed",
      "comment": "Test fixtures with mock credentials"
    },
    {
      "file": "config/example.yml",
      "rule": "db-password-exposed",
      "comment": "Example configuration template"
    }
  ],
  "security_team": [
    "@security-leads",
    "security@company.com"
  ],
  "require_approval_count": 2,
  "bypass_required_for": [
    "CRITICAL",
    "HIGH"
  ],
  "audit_log": {
    "enabled": true,
    "format": "json"
  }
}
